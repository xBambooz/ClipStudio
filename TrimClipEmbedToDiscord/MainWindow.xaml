<Window x:Class="BamboozClipStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BamboozClipStudio.Views"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Bambooz Clip Studio"
        Height="720" Width="1100" MinHeight="540" MinWidth="800"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBg}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <!-- Toolbar / title bar -->
            <RowDefinition Height="*"/>
            <!-- Preview + filters -->
            <RowDefinition Height="160"/>
            <!-- Timeline -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════
             ROW 0 — Toolbar / Title bar
             ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ToolbarBg}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- App name -->
                    <ColumnDefinition Width="*"/>
                    <!-- Menu items -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Export + window controls -->
                </Grid.ColumnDefinitions>

                <!-- App name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0,0,0">
                    <Ellipse Width="18" Height="18" Fill="{DynamicResource Accent}" Margin="0,0,8,0"/>
                    <TextBlock Text="Bambooz Clip Studio"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Menu buttons (center-left) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0,0,0">

                    <!-- File menu -->
                    <Button Style="{StaticResource IconButton}" Padding="10,6"
                            Click="FileMenu_Click" x:Name="FileMenuBtn">
                        <TextBlock Text="File" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="FileContextMenu">
                                <MenuItem Header="Open Media…" Click="OpenMedia_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="📂" FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Filters button -->
                    <Button Style="{StaticResource IconButton}" Padding="10,6"
                            Command="{Binding ToggleFiltersCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Filters" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <!-- Active indicator dot -->
                            <Ellipse Width="5" Height="5" Fill="{DynamicResource Accent}"
                                     Margin="4,0,0,0" VerticalAlignment="Center"
                                     Visibility="{Binding Filters.HasFilters, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Button>

                    <!-- Tools menu -->
                    <Button Style="{StaticResource IconButton}" Padding="10,6"
                            Click="ToolsMenu_Click">
                        <TextBlock Text="Tools" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Check for Updates on Startup" x:Name="AutoUpdateMenuItem"
                                          IsCheckable="True"
                                          IsChecked="{Binding AutoCheckUpdates}"
                                          Click="AutoUpdate_Click"/>
                                <MenuItem Header="Check for Updates Now" Command="{Binding CheckUpdatesCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Settings button -->
                    <Button Style="{StaticResource IconButton}" Padding="10,6"
                            Click="SettingsMenu_Click" x:Name="SettingsMenuBtn">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.67,8.73L19.67,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.33,5.27L2.33,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.33,15.27L4.33,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.67,18.73L21.67,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Canvas>
                        </Viewbox>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="SettingsContextMenu">
                                <MenuItem Header="Theme">
                                    <MenuItem Header="System / Auto" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeAuto, Mode=OneWay}"
                                              Click="Theme_Auto_Click"/>
                                    <MenuItem Header="Dark" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeDark, Mode=OneWay}"
                                              Click="Theme_Dark_Click"/>
                                    <MenuItem Header="Light" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeLight, Mode=OneWay}"
                                              Click="Theme_Light_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Mint Dark" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeMintDark, Mode=OneWay}"
                                              Click="Theme_MintDark_Click"/>
                                    <MenuItem Header="Red Dark" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeRedDark, Mode=OneWay}"
                                              Click="Theme_RedDark_Click"/>
                                    <MenuItem Header="Premiere Pro" IsCheckable="True"
                                              IsChecked="{Binding ThemeModePremierePro, Mode=OneWay}"
                                              Click="Theme_PremierePro_Click"/>
                                    <MenuItem Header="OLED" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeOLED, Mode=OneWay}"
                                              Click="Theme_OLED_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Discord" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeDiscord, Mode=OneWay}"
                                              Click="Theme_Discord_Click"/>
                                    <MenuItem Header="Twilight Blurple" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeTwilightBlurple, Mode=OneWay}"
                                              Click="Theme_TwilightBlurple_Click"/>
                                    <MenuItem Header="YouTube Dark" IsCheckable="True"
                                              IsChecked="{Binding ThemeModeYouTube, Mode=OneWay}"
                                              Click="Theme_YouTube_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Hardware Acceleration" IsCheckable="True"
                                          IsChecked="{Binding HardwareAcceleration, Mode=OneWay}"
                                          Click="HwAccel_Click"/>
                                <MenuItem Header="Mix Audio Tracks" IsCheckable="True"
                                          IsChecked="{Binding MixAudioTracks, Mode=OneWay}"
                                          Click="MixAudio_Click"/>
                                <Separator/>
                                <MenuItem Header="Register Right-Click Menu" Click="RegisterContextMenu_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Border Margin="12,0,0,0" Padding="10,4"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Visibility="{Binding Jobs.IsBusy, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ProgressBar Width="72" Height="5"
                                         Margin="0,0,8,0"
                                         Value="{Binding Jobs.CurrentJobProgress, Mode=OneWay}"
                                         IsIndeterminate="{Binding Jobs.IsIndeterminate}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Jobs.CurrentJobTitle}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Jobs.CurrentJobStatus}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="10"/>
                            </StackPanel>
                            <Button Style="{StaticResource IconButton}"
                                    Padding="6,2"
                                    Margin="8,0,0,0"
                                    Click="CancelBackgroundJob_Click"
                                    IsEnabled="{Binding Jobs.CanCancel}">
                                <TextBlock Text="Cancel"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right side: Export button + window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">

                    <!-- Export button -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Margin="0,8,12,8" Padding="16,0"
                            IsEnabled="{Binding HasMedia}"
                            Click="Export_Click">
                        <StackPanel Orientation="Horizontal">
                            <!-- Upload icon -->
                            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 2L12 16M12 2L7 7M12 2L17 7M4 20H20"
                                          Stroke="{DynamicResource TextOnAccent}" StrokeThickness="2.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Export" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextOnAccent}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Window controls -->
                    <Button Style="{StaticResource WinControlButton}"
                            Click="Minimize_Click" ToolTip="Minimize">
                        <Path Data="M 0 0 L 10 0" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Width="10" Stretch="None"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource WinControlButton}"
                            Click="Maximize_Click" x:Name="MaximizeBtn" ToolTip="Maximize">
                        <Border BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                BorderThickness="1.5" Width="11" Height="11"/>
                    </Button>

                    <Button Style="{StaticResource CloseButton}"
                            Click="Close_Click" ToolTip="Close">
                        <Path Data="M 0 0 L 10 10 M 10 0 L 0 10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Width="11" Height="11" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════
             ROW 1 — Preview area + Filters side panel
             ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Preview -->
                <ColumnDefinition Width="Auto"/>
                <!-- Filters panel (collapsible) -->
            </Grid.ColumnDefinitions>

            <!-- Preview area -->
            <Grid Grid.Column="0" Background="{DynamicResource DropZoneBg}"
                  x:Name="PreviewArea">

                <!-- Full-area click overlay (shown when no media) -->
                <Grid Background="Transparent"
                      Cursor="Hand"
                      MouseLeftButtonDown="DropZone_Click"
                      Visibility="{Binding HasMedia, Converter={StaticResource InverseBoolToVis}}"/>

                <!-- Drop zone (shown when no media) -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsHitTestVisible="False"
                            Visibility="{Binding HasMedia, Converter={StaticResource InverseBoolToVis}}">
                    <!-- Circle with upload icon -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            BorderBrush="{DynamicResource Border}" BorderThickness="2"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Viewbox Width="36" Height="36">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12 4L12 16M12 4L7 9M12 4L17 9"
                                      Stroke="{DynamicResource Accent}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Path Data="M4 20H20" Stroke="{DynamicResource Border}" StrokeThickness="2"
                                      StrokeStartLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Click to open a video file"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="or drag and drop here"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="MP4 · MKV · MOV · AVI · WebM"
                               Foreground="{DynamicResource TextDisabled}"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding DependencyStatus}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <!-- VLC video player — only visible during playback (avoids WinForms airspace issue) -->
                <vlc:VideoView x:Name="VideoPlayer"
                               Background="{DynamicResource DropZoneBg}"
                               Visibility="{Binding ShowVideoPlayer, Converter={StaticResource BoolToVis}}"/>

                <!-- Filter preview overlay (shown when paused) -->
                <Image Source="{Binding PreviewFrame}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="{Binding ShowPreviewImage, Converter={StaticResource BoolToVis}}"/>

                <!-- Loading overlay -->
                <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Background="#CC0F0F0F">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LoadingStatus}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="13" HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding LoadingDetail}"
                                   Foreground="{DynamicResource TextDisabled}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <ProgressBar Width="220" IsIndeterminate="{Binding IsLoadingIndeterminate}"
                                     Value="{Binding LoadingProgress, Mode=OneWay}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filters panel (slides in/out) -->
            <views:FiltersPanel Grid.Column="1"
                                DataContext="{Binding Filters}"
                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
        </Grid>

        <!-- ══════════════════════════════════════════════════
             ROW 2 — Timeline
             ══════════════════════════════════════════════════ -->
        <views:TimelineView Grid.Row="2"
                            DataContext="{Binding Timeline}"/>

    </Grid>
</Window>
