<Application x:Class="BamboozClipStudio.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:BamboozClipStudio.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/UIColors.xaml"/>
                <ResourceDictionary Source="Theme/UIStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:DoneToCloseTextConverter x:Key="DoneToClose"/>
            <conv:EnumToIndexConverter x:Key="EnumToIndex"/>
            <conv:StringToVisibilityConverter x:Key="StringToVis"/>
            <DropShadowEffect x:Key="ShadowDepth2" BlurRadius="16" ShadowDepth="2" Color="Black" Opacity="0.5"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
