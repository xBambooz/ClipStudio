<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === Core Colors (Light) === -->
    <Color x:Key="AppBgColor">#F0F0F0</Color>
    <Color x:Key="ToolbarBgColor">#E4E4E4</Color>
    <Color x:Key="PanelBgColor">#E8E8E8</Color>
    <Color x:Key="TimelineBgColor">#D8D8D8</Color>
    <Color x:Key="DropZoneBgColor">#EAEAEA</Color>
    <Color x:Key="InputBgColor">#FFFFFF</Color>
    <Color x:Key="HoverBgColor">#D8D8D8</Color>
    <Color x:Key="ActiveBgColor">#CCCCCC</Color>

    <Color x:Key="AccentColor">#00A0AA</Color>
    <Color x:Key="AccentHoverColor">#00C8D4</Color>
    <Color x:Key="AccentPressedColor">#007880</Color>
    <Color x:Key="AccentAlpha">#3300A0AA</Color>

    <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#555555</Color>
    <Color x:Key="TextDisabledColor">#AAAAAA</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <Color x:Key="BorderColor">#C0C0C0</Color>
    <Color x:Key="BorderSubtleColor">#D0D0D0</Color>
    <Color x:Key="SeparatorColor">#CCCCCC</Color>

    <Color x:Key="DangerColor">#CC2222</Color>
    <Color x:Key="SuccessColor">#2A8C2A</Color>

    <!-- === Brushes === -->
    <SolidColorBrush x:Key="AppBg"           Color="{StaticResource AppBgColor}"/>
    <SolidColorBrush x:Key="ToolbarBg"       Color="{StaticResource ToolbarBgColor}"/>
    <SolidColorBrush x:Key="PanelBg"         Color="{StaticResource PanelBgColor}"/>
    <SolidColorBrush x:Key="TimelineBg"      Color="{StaticResource TimelineBgColor}"/>
    <SolidColorBrush x:Key="DropZoneBg"      Color="{StaticResource DropZoneBgColor}"/>
    <SolidColorBrush x:Key="InputBg"         Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="HoverBg"         Color="{StaticResource HoverBgColor}"/>
    <SolidColorBrush x:Key="ActiveBg"        Color="{StaticResource ActiveBgColor}"/>

    <SolidColorBrush x:Key="Accent"          Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHover"     Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressed"   Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentAlphaBrush" Color="{StaticResource AccentAlpha}"/>

    <SolidColorBrush x:Key="TextPrimary"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="{StaticResource TextOnAccentColor}"/>

    <SolidColorBrush x:Key="Border"          Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtle"    Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="Separator"       Color="{StaticResource SeparatorColor}"/>

    <SolidColorBrush x:Key="Danger"          Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="Success"         Color="{StaticResource SuccessColor}"/>

</ResourceDictionary>
