<UserControl x:Class="BamboozClipStudio.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BamboozClipStudio.ViewModels"
             Background="{DynamicResource TimelineBg}">

    <UserControl.Resources>
        <Style x:Key="TransportBtn" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="1,0"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Timeline canvas -->
            <RowDefinition Height="44"/>
            <!-- Transport bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Timeline Canvas ═══ -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <!-- Track header (V1 label) -->
                    <ColumnDefinition Width="*"/>
                    <!-- Scrollable timeline -->
                </Grid.ColumnDefinitions>

                <!-- Track header — Premiere-style V1 label -->
                <Border Grid.Column="0" Background="#1A1A1A"
                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0">
                    <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                        <!-- Track color indicator + label -->
                        <Border Height="3" Background="{DynamicResource Accent}" Margin="4,0"/>
                        <TextBlock Text="V1" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable timeline area -->
                <ScrollViewer Grid.Column="1" x:Name="TimelineScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="TimelineScroller_PreviewMouseWheel">
                    <Canvas x:Name="TimelineCanvas"
                            Height="110"
                            Background="{DynamicResource TimelineBg}"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                            MouseLeave="Canvas_MouseLeave"
                            Cursor="Arrow">

                        <!-- Ruler (drawn via code-behind) -->
                        <Canvas x:Name="RulerCanvas" Canvas.Top="0" Height="20"/>

                        <!-- Clip container outline — Premiere-style clip border -->
                        <Border x:Name="ClipBorder"
                                Canvas.Top="20" Height="90"
                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1"
                                CornerRadius="2"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <SolidColorBrush Color="#0A0A0A"/>
                            </Border.Background>
                        </Border>

                        <!-- Clip color bar — thin accent strip at top of clip (Premiere style) -->
                        <Rectangle x:Name="ClipColorBar"
                                   Canvas.Top="20" Height="3"
                                   Fill="{DynamicResource Accent}"
                                   IsHitTestVisible="False"/>

                        <!-- Clip filename label (Premiere shows source name at top of clip) -->
                        <TextBlock x:Name="ClipFilename"
                                   Canvas.Top="24"
                                   FontSize="10" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Opacity="0.7"
                                   IsHitTestVisible="False"
                                   Margin="6,0,0,0"/>

                        <!-- Thumbnails (dynamically added in code-behind) -->

                        <!-- In/out selection tint (subtle highlight over selected region) -->
                        <Border x:Name="HighlightRegion"
                                Canvas.Top="20" Height="90"
                                IsHitTestVisible="False"
                                Opacity="0.12"
                                Background="{DynamicResource Accent}"/>

                        <!-- Dimmed region BEFORE in-point -->
                        <Border x:Name="DimBefore"
                                Canvas.Top="20" Height="90"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <SolidColorBrush Color="#000000" Opacity="0.55"/>
                            </Border.Background>
                        </Border>

                        <!-- Dimmed region AFTER out-point -->
                        <Border x:Name="DimAfter"
                                Canvas.Top="20" Height="90"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <SolidColorBrush Color="#000000" Opacity="0.55"/>
                            </Border.Background>
                        </Border>

                        <!-- In handle — Premiere-style thin trim bracket -->
                        <Border x:Name="InHandle"
                                Canvas.Top="20" Width="6" Height="90"
                                Cursor="SizeWE"
                                ToolTip="Drag to set In point"
                                MouseLeftButtonDown="InHandle_MouseDown">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.35"/>
                            </Border.Background>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#FFFFFF" Opacity="0.7"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <!-- Grip lines -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Rectangle Width="2" Height="12" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource TextPrimary}" Opacity="0.5"/>
                            </StackPanel>
                        </Border>

                        <!-- Out handle — Premiere-style thin trim bracket -->
                        <Border x:Name="OutHandle"
                                Canvas.Top="20" Width="6" Height="90"
                                Cursor="SizeWE"
                                ToolTip="Drag to set Out point"
                                MouseLeftButtonDown="OutHandle_MouseDown">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.35"/>
                            </Border.Background>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#FFFFFF" Opacity="0.7"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Rectangle Width="2" Height="12" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource TextPrimary}" Opacity="0.5"/>
                            </StackPanel>
                        </Border>

                        <!-- Hover preview tooltip (thumbnail + timecode) -->
                        <Border x:Name="HoverTooltip"
                                Canvas.Top="-78" Height="72"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                CornerRadius="4"
                                BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                                Background="#E0101010">
                            <StackPanel>
                                <Image x:Name="HoverThumb"
                                       Width="112" Height="54"
                                       Stretch="UniformToFill" ClipToBounds="True"
                                       RenderOptions.BitmapScalingMode="LowQuality"/>
                                <TextBlock x:Name="HoverTimecode"
                                           FontSize="10" FontFamily="Consolas"
                                           Foreground="{DynamicResource TextPrimary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Playhead — thin line with downward arrow -->
                        <Canvas x:Name="PlayheadCanvas" Canvas.Top="0" Width="2"
                                IsHitTestVisible="False">
                            <Rectangle x:Name="PlayheadLine"
                                       Width="2" Height="110"
                                       Fill="{DynamicResource Accent}"
                                       Opacity="0.9"/>
                            <!-- Downward triangle at top -->
                            <Polygon Points="0,0 10,0 5,8"
                                     Fill="{DynamicResource Accent}"
                                     Canvas.Left="-4"/>
                        </Canvas>

                    </Canvas>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ Transport Bar ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Filename (left) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0">
                    <!-- Filename pill -->
                    <Border Background="{DynamicResource TimelineBg}" CornerRadius="3"
                            Padding="6,2" Margin="0,0,8,0"
                            Visibility="{Binding FileName, Converter={StaticResource StringToVis}}">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="11" FontWeight="SemiBold"
                                   MaxWidth="180" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FileName}"/>
                    </Border>
                </StackPanel>

                <!-- Transport controls (center) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Center">

                    <Button Style="{StaticResource TransportBtn}"
                            Command="{Binding GoToStartCommand}"
                            ToolTip="Go to start">
                        <Path Data="M 0 0 L 0 10 M 2 5 L 10 0 L 10 10 Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="12" Height="10" Stretch="Uniform"/>
                    </Button>

                    <Button Style="{StaticResource TransportBtn}"
                            Command="{Binding StepBackCommand}"
                            ToolTip="Step back one frame">
                        <Path Data="M 10 0 L 2 5 L 10 10 M 0 0 L 0 10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Width="12" Height="10" Stretch="Uniform"/>
                    </Button>

                    <!-- Play/Pause - bigger -->
                    <Button x:Name="PlayPauseBtn"
                            Style="{StaticResource TransportBtn}"
                            Width="40" Height="40"
                            Command="{Binding PlayPauseCommand}"
                            ToolTip="Play / Pause (Space)">
                        <Grid>
                            <!-- Play icon -->
                            <Path x:Name="PlayIcon" Data="M 0 0 L 14 7 L 0 14 Z"
                                  Fill="{DynamicResource Accent}" Width="14" Height="14" Stretch="Uniform"/>
                            <!-- Pause icon -->
                            <StackPanel x:Name="PauseIcon" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Rectangle Width="4" Height="14" Fill="{DynamicResource Accent}" RadiusX="1" RadiusY="1" Margin="0,0,3,0"/>
                                <Rectangle Width="4" Height="14" Fill="{DynamicResource Accent}" RadiusX="1" RadiusY="1"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource TransportBtn}"
                            Command="{Binding StepForwardCommand}"
                            ToolTip="Step forward one frame">
                        <Path Data="M 0 0 L 8 5 L 0 10 M 10 0 L 10 10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Width="12" Height="10" Stretch="Uniform"/>
                    </Button>

                    <Button Style="{StaticResource TransportBtn}"
                            Command="{Binding GoToEndCommand}"
                            ToolTip="Go to end">
                        <Path Data="M 0 0 L 8 5 L 0 10 M 10 0 L 10 10"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Width="12" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <!-- Timecode + zoom + volume (right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right"
                            Margin="0,0,12,0">

                    <TextBlock x:Name="PositionTimecode"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Button Style="{StaticResource TransportBtn}" Click="ZoomOut_Click" ToolTip="Zoom out (Ctrl+Wheel)">
                        <TextBlock Text="－" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>
                    <Button Style="{StaticResource TransportBtn}" Click="ZoomIn_Click" ToolTip="Zoom in (Ctrl+Wheel)">
                        <TextBlock Text="＋" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>
                    <Button Style="{StaticResource TransportBtn}" Click="ZoomReset_Click" ToolTip="Fit timeline">
                        <TextBlock Text="⊡" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>

                    <!-- Divider -->
                    <Border Width="1" Height="16" Background="{DynamicResource Border}" Margin="6,0" VerticalAlignment="Center"/>

                    <!-- Mute toggle button -->
                    <Button x:Name="MuteBtn" Style="{StaticResource TransportBtn}"
                            ToolTip="Mute / Unmute" Click="Mute_Click">
                        <Viewbox Width="15" Height="15">
                            <Canvas Width="24" Height="24">
                                <Path x:Name="SpeakerIcon"
                                      Data="M11,5 L6,9 H2 V15 H6 L11,19 V5 Z M14,9 Q17,12 14,15 M17,6 Q22,12 17,18"
                                      Stroke="{DynamicResource TextSecondary}" StrokeThickness="2"
                                      Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                <Path x:Name="MuteIcon" Visibility="Collapsed"
                                      Data="M11,5 L6,9 H2 V15 H6 L11,19 V5 Z M16,10 L21,15 M21,10 L16,15"
                                      Stroke="{DynamicResource Danger}" StrokeThickness="2"
                                      Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Volume slider -->
                    <Slider x:Name="VolumeSlider"
                            Width="72" Height="14"
                            Minimum="0" Maximum="1"
                            Value="{Binding Volume, Mode=TwoWay}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            Margin="2,0,0,0"
                            ToolTip="Volume"/>

                    <!-- Volume % label -->
                    <TextBlock Text="{Binding VolumePercent}"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               MinWidth="30"/>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
