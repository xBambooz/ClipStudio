<Window x:Class="BamboozClipStudio.Views.UploadProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uploading…" Height="220" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{StaticResource PanelBg}"
        BorderBrush="{StaticResource Border}" BorderThickness="1">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Uploading to catbox.moe"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}"/>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="4" Height="6"
                     Value="{Binding ProgressPercent}"
                     IsIndeterminate="{Binding IsIndeterminate}"/>

        <!-- Embed URL (visible when done) -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.Visibility>
                <Binding Path="IsDone">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBox Grid.Row="0" Text="{Binding EmbedUrl, Mode=OneWay}"
                     IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                     Foreground="{StaticResource Accent}"/>
            <TextBlock Grid.Row="2" Text="✓ Copied to clipboard!"
                       Foreground="{StaticResource Success}" FontSize="11"
                       Visibility="{Binding UrlCopied, Converter={StaticResource BoolToVis}}"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Style="{StaticResource SecondaryButton}"
                    Content="Copy Link"
                    Command="{Binding CopyUrlCommand}"
                    Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,8,0"/>
            <Button Style="{StaticResource SecondaryButton}"
                    Content="{Binding IsDone, Converter={StaticResource DoneToClose}}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
